---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Main from '../../layouts/main.astro';
import ScheduleSection from '../../components/schedule/ScheduleSection.astro';
import CtaBand from '../../components/sections/CtaBand.astro';
import ModalShell from '../../components/modals/ModalShell.astro';
import EventsData from '../../components/events/EventsData.astro';
import ScheduleData from '../../components/schedule/ScheduleData.astro';
import { localePathParams } from '../../i18n/locales';
import { resolveLocalePageContext } from '../../i18n/pageContext';
import { translations } from '../../i18n/translations';
import { getHero } from '../../utils/sanity/hero';

export function getStaticPaths() {
	return localePathParams();
}

const pageContext = resolveLocalePageContext(Astro.params.locale);
if (!pageContext) return Astro.redirect('/');

const { locale, lang } = pageContext;
const hero = await getHero(lang);
const t = translations[lang];
const scheduleHref = getRelativeLocaleUrl(locale, 'schedule');
const eventsHref = getRelativeLocaleUrl(locale, 'events');
const aboutHref = getRelativeLocaleUrl(locale, 'about');
---

<Main
	title="Zé Radiola Team — Brazilian Jiu-Jitsu"
	description="Brazilian Jiu-Jitsu in Košice and Bratislava. Two academies, one team."
	currentPath=""
	lang={lang}
	locale={locale}
>
	<div class="mx-auto max-w-7xl pb-12 md:pb-16 lg:pb-20">
		<div class="hero-grid grid min-h-[520px] grid-cols-[1.05fr_0.95fr]">
			<div class="flex flex-col justify-center px-10 py-20">
				<div class="font-condensed mb-4 text-[15px] font-semibold tracking-[5px] text-zr-green">
					{hero.kicker}
				</div>
				<h1
					class="hero-title font-display text-[66px] leading-none font-bold text-white uppercase"
				>
					{hero.title}
				</h1>
				<p class="mt-6 max-w-[490px] text-lg leading-relaxed text-zr-text-secondary">
					{hero.subtitle}
				</p>
				<div class="mt-9 flex gap-3.5">
					<button
						type="button"
						data-action="open-trial"
						class="font-condensed cursor-pointer rounded bg-zr-green px-9 py-4 text-[17px] font-bold tracking-wider text-zr-bg uppercase"
					>
						{t.ctaTrial}
					</button>
					<a
						href={scheduleHref}
						class="font-condensed rounded border border-white/25 px-9 py-4 text-[17px] font-semibold tracking-wider text-white uppercase"
					>
						{t.ctaSchedule}
					</a>
				</div>
				<div class="mt-12 flex gap-9">
					{hero.stats.map((stat) => (
						<div>
							<div class="font-display text-[34px] font-bold text-zr-green">{stat.value}</div>
							<div class="text-[13px] tracking-wide text-zr-text-dim">{stat.label}</div>
						</div>
					))}
				</div>
			</div>
			<div
				class="ph relative flex items-end overflow-hidden bg-zr-bg-surface"
				style="clip-path: polygon(10% 0, 100% 0, 100% 100%, 0 100%)"
			>
				{hero.imageUrl ? (
					<img
						src={hero.imageUrl}
						alt={hero.imageAlt}
						class="absolute inset-0 h-full w-full object-cover"
						loading="eager"
						decoding="async"
					/>
				) : null}
				<img
					src="/zr-logo.svg"
					alt=""
					class="absolute -right-[90px] -bottom-[60px] w-[380px] opacity-[0.08]"
					aria-hidden="true"
				/>
				{!hero.imageUrl && (
					<span class="relative p-5 font-mono text-xs tracking-wide text-[#5a6a5d]">
						[ training / roll photo ]
					</span>
				)}
			</div>
		</div>

		<section id="schedule" class="border-t border-white/7 px-10 py-16">
			<ScheduleSection lang={lang} kickerKey="schedKicker" titleKey="schedTitle" />
		</section>

		<section class="border-t border-white/7 px-10 py-16">
			<div class="mb-7 flex items-end justify-between">
				<div>
					<div
						class="font-condensed mb-2 text-sm font-semibold tracking-[4px] text-zr-green"
					>
						{t.eventsKicker}
					</div>
					<div
						class="font-display text-[34px] leading-none font-bold text-white uppercase"
					>
						{t.eventsTitle}
					</div>
				</div>
				<a
					href={eventsHref}
					data-events-show-more
					class="font-condensed cursor-pointer text-sm font-bold tracking-wide text-zr-green uppercase"
				>
					{t.showMore} →
				</a>
			</div>
			<div class="events-preview-grid grid grid-cols-3 gap-4" data-events-preview></div>
		</section>

		<section class="border-t border-white/7 px-10 py-16">
			<div class="about-grid grid grid-cols-2 items-center gap-12">
				<div>
					<div
						class="font-condensed mb-2.5 text-sm font-semibold tracking-[4px] text-zr-green"
					>
						{t.aboutKicker}
					</div>
					<div
						class="font-display text-4xl leading-tight font-bold text-white uppercase"
					>
						{t.aboutTitle}
					</div>
					<p class="mt-5 text-base leading-relaxed text-zr-text-secondary">
						{t.aboutBody1}
					</p>
					<a
						href={aboutHref}
						class="font-condensed mt-6 inline-block text-[15px] font-bold tracking-wider text-zr-green uppercase"
					>
						{t.aboutTeaserCta} →
					</a>
				</div>
				<div class="flex flex-col gap-3.5" data-locations data-locations-variant="teaser"></div>
			</div>
		</section>

		<section class="border-t border-white/7 px-10 py-16 text-center">
			<div
				class="font-condensed mb-2.5 text-sm font-semibold tracking-[4px] text-zr-green"
			>
				{t.sponsorsKicker}
			</div>
			<div
				class="font-display mb-2 text-[34px] leading-none font-bold text-white uppercase"
			>
				{t.sponsorsTitle}
			</div>
			<p class="mx-auto mb-8 max-w-[520px] text-[15px] text-zr-text-muted">
				{t.partnersTeaserSub}
			</p>
			<div class="partners-grid grid grid-cols-4 gap-4" data-partners-grid data-partners-count="4"></div>
			<button
				type="button"
				data-action="open-partner"
				class="font-condensed mt-8 inline-block cursor-pointer rounded bg-zr-green px-10 py-4 text-base font-bold tracking-wider text-zr-bg uppercase"
			>
				{t.becomePartner}
			</button>
		</section>

		<CtaBand lang={lang} />
	</div>

	<ModalShell slot="modals" />
	<ScheduleData slot="modals" />
	<EventsData slot="modals" lang={lang} />
</Main>
