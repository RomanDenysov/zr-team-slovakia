---
import Main from '../../layouts/main.astro';
import CtaBand from '../../components/sections/CtaBand.astro';
import ModalShell from '../../components/modals/ModalShell.astro';
import { localePathParams } from '../../i18n/locales';
import { resolveLocalePageContext } from '../../i18n/pageContext';
import { translations } from '../../i18n/translations';

export function getStaticPaths() {
	return localePathParams();
}

const pageContext = resolveLocalePageContext(Astro.params.locale);
if (!pageContext) return Astro.redirect('/');

const { locale, lang } = pageContext;
const t = translations[lang];
---

<Main title="O nás — ZR Team" currentPath="about" lang={lang} locale={locale}>
	<div class="mx-auto max-w-[1140px] px-10 py-16">
		<div class="max-w-[760px]">
			<div
				class="font-condensed mb-2.5 text-sm font-semibold tracking-[4px] text-zr-green"
			>
				{t.wayKicker}
			</div>
			<h1 class="font-display text-5xl leading-tight font-bold text-white uppercase">
				{t.wayTitle}
			</h1>
			<p class="mt-5 text-[17px] leading-relaxed text-zr-text-secondary">
				{t.wayIntro}
			</p>
		</div>

		<div class="way-grid mt-10 grid grid-cols-2 gap-4" data-way-items></div>

		<section class="mt-14 border-t border-white/7 pt-12">
			<h2
				class="font-display mb-1.5 text-[30px] leading-none font-bold text-white uppercase"
			>
				{t.aboutTitle}
			</h2>
			<p class="mb-6 text-[13px] text-zr-text-faint">{t.aboutClickHint}</p>
			<div class="grid grid-cols-2 gap-4" data-locations data-locations-variant="full"></div>
		</section>
	</div>

	<CtaBand lang={lang} />

	<ModalShell slot="modals" />
</Main>
