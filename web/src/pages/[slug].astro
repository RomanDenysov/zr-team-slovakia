---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { PortableText } from 'astro-portabletext';
import Main from '../layouts/main.astro';
import { getStaticPagePaths } from '../utils/sanity';
import { defaultLocale, localeToLang } from '../i18n/locales';
import type { PAGE_PATHS_QUERY_RESULT } from '../../sanity.types';

export async function getStaticPaths() {
	return getStaticPagePaths();
}

type Page = NonNullable<PAGE_PATHS_QUERY_RESULT[number]>;

interface Props {
	page: Page;
}

const { page } = Astro.props;
const locale = defaultLocale;
const lang = localeToLang(locale);
const homeHref = getRelativeLocaleUrl(locale, '');
---

<Main
	title={`${page.title ?? 'Page'} — ZR Team`}
	description={page.excerpt ?? undefined}
	currentPath={page.slug ?? ''}
	lang={lang}
	locale={locale}
>
	<div class="mx-auto max-w-3xl px-10 py-16">
		<a
			class="font-condensed text-sm font-bold tracking-wide text-zr-green uppercase hover:underline"
			href={homeHref}
		>
			← Home
		</a>
		<article class="mt-8">
			<h1 class="font-display text-4xl leading-tight font-bold text-white uppercase">
				{page.title}
			</h1>
			{page.excerpt && (
				<p class="mt-4 text-lg leading-relaxed text-zr-text-secondary">{page.excerpt}</p>
			)}
			{page.body && (
				<div class="prose prose-invert mt-8 max-w-none">
					<PortableText value={page.body} />
				</div>
			)}
		</article>
	</div>
</Main>
