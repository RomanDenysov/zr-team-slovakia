---
import { getUiString } from '../../i18n/runtime';
import type { Lang } from '../../i18n/translations';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="border-t border-white/7 bg-zr-bg-footer">
	<div
		class="mx-auto flex max-w-[1240px] flex-wrap items-center justify-between gap-5 px-10 py-11"
	>
		<div class="flex items-center gap-3.5">
			<img src="/zr-logo.svg" alt="ZRTeam" class="h-10 w-10" width="40" height="40" />
			<div class="font-condensed text-[15px] font-bold tracking-wide text-white">
				ZÉ RADIOLA TEAM
				<div class="font-body text-[11px] tracking-wide text-zr-text-faint">
					Brazilian Jiu-Jitsu · Slovakia
				</div>
			</div>
		</div>

		<div class="flex gap-6 text-[13px] font-semibold text-zr-text-muted">
			<span class="cursor-default">Instagram</span>
			<span class="cursor-default">Facebook</span>
			<span class="cursor-default">YouTube</span>
		</div>

		<div class="text-xs text-[#5a6259]">
			© 2026 ZRTeam · <span>{getUiString('footerRights', lang)}</span>
		</div>
	</div>
</footer>
